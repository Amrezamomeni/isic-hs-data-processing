import pandas as pd
import re
from google.colab import files

# تنظیمات فایل
input_file = "Book2.xlsx"
output_file = "Final_Report.xlsx"
target_column = "کد 8 رقمی ایران"

def normalize_hs(code):
    if pd.isna(code): return ""
    code = str(code).strip()
    if code.endswith(".0"): code = code[:-2]
    digits = re.sub(r"\D", "", code)
    if not digits: return ""
    # اصلاح کدهای 7 رقمی به 8 رقمی با حفظ صفر اول
    return digits.zfill(8) if len(digits) < 8 else digits[:8]

def get_section_name(hs_code):
    if not hs_code or len(hs_code) < 2: return ""
    chapter = int(hs_code[:2])

    # دسته‌بندی با عناوین حروفی برای جلوگیری از به هم ریختگی اعداد
    sections = {
        (1, 5): "بخش اول: حیوانات زنده و محصولات حیوانی",
        (6, 14): "بخش دوم: محصولات نباتی (گیاهی)",
        (15, 15): "بخش سوم: چربی‌ها و روغن‌های حیوانی و نباتی",
        (16, 24): "بخش چهارم: مواد غذایی آماده، نوشیدنی، دخانیات",
        (25, 27): "بخش پنجم: مواد معدنی",
        (28, 38): "بخش ششم: محصولات صنایع شیمیایی و صنایع وابسته",
        (39, 40): "بخش هفتم: پلاستیک و اشیاءِ ساخته‌شده از پلاستیک؛ لاستیک",
        (41, 43): "بخش هشتم: چرم، پوست، اشیاءِ ساخته‌شده از چرم",
        (44, 46): "بخش نهم: چوب و اشیاءِ چوبی؛ چوب‌پنبه",
        (47, 49): "بخش دهم: خمیر چوب، کاغذ و محصولات کاغذی",
        (50, 63): "بخش یازدهم: منسوجات و مصنوعات نساجی",
        (64, 67): "بخش دوازدهم: کفش، کلاه و سایر پوشاک سر",
        (68, 70): "بخش سیزدهم: مصنوعات سنگ، گچ، سیمان؛ شیشه",
        (71, 71): "بخش چهاردهم: مروارید، سنگ‌های قیمتی، فلزات گران‌بها",
        (72, 83): "بخش پانزدهم: فلزات معمولی و مصنوعات آن‌ها",
        (84, 85): "بخش شانزدهم: ماشین‌آلات و وسایل مکانیکی؛ تجهیزات الکتریکی",
        (86, 89): "بخش هفدهم: وسایل نقلیه زمینی، هوایی، آبی",
        (90, 92): "بخش هجدهم: ادوات نوری، عکاسی، پزشکی؛ ساعت",
        (93, 93): "بخش نوزدهم: سلاح و مهمات",
        (94, 96): "بخش بیستم: کالاها و اشیاءِ متفرقه ساخته‌شده",
        (97, 97): "بخش بیست و یکم: آثار هنری، اشیاءِ کلکسیونی و عتیقه"
    }

    for (start, end), name in sections.items():
        if start <= chapter <= end:
            return name
    return "نامشخص"

# اجرای پردازش در Colab
try:
    df = pd.read_excel(input_file, dtype=str)
    df.columns = df.columns.str.strip()

    # ایجاد ستون سربخش بر اساس منطق جدید
    df["HS_Temp"] = df[target_column].apply(normalize_hs)
    df["سربخش"] = df["HS_Temp"].apply(get_section_name)
    
    # حذف ستون کمکی و ذخیره خروجی
    df.drop(columns=["HS_Temp"], inplace=True)
    df.to_excel(output_file, index=False)
    
    print("✅ فایل نهایی با موفقیت آماده شد.")
    files.download(output_file)
except Exception as e:
    print(f"❌ خطایی رخ داد: {e}")
